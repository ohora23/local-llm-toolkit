# ─── local-llm-toolkit — machine-specific config ────────────────────
# Copy to `config.env` and edit for your machine, then it is sourced
# automatically by the toolkit. `config.env` is gitignored (never shared).
#
# The repo root is auto-detected from each script's location, so you only
# need to point at the EXTERNAL things: your model store and the engine
# checkouts you built. Defaults assume a ~/0_AI/... layout.

# Shared model store (GGUF etc.) — large, lives outside the repo.
export MODEL_STORE="${MODEL_STORE:-$HOME/b_Models}"

# llama.cpp checkout. Needs two builds:
#   $LLAMA_DIR/build/bin/llama-server      (CUDA build, for GPU serving)
#   $LLAMA_DIR/build-cpu/bin/llama-server  (CPU-only: -DGGML_CUDA=OFF, VRAM 0)
export LLAMA_DIR="${LLAMA_DIR:-$HOME/0_AI/llama.cpp}"

# ik_llama.cpp checkout (CUDA build for hybrid gpt-oss MoE offload).
#   $IK_DIR/build/bin/llama-server
export IK_DIR="${IK_DIR:-$HOME/0_AI/ik_llama.cpp}"

# ── Optional: override default endpoint ports (see the `llm` CLI) ────
# export GPU_PORT=5000 CPU_PORT=5001 HYB_PORT=5002 KO_PORT=5003
